# Fill Level Estimator API Configuration
# Copy this file to .env and update the paths as needed

# Model Paths
MODEL_PATH=Model/SAM/BEST_model.pth
YOLO_PATH=Model/YOLO/yolox_m_daniels_adarsh.onnx

# YOLO Thresholds
YOLO_CONF_THR=0.8
YOLO_NMS_THR=0.8

# Processing Parameters
MASK_THRESHOLD=0.30
NUM_LINES=100
STEP_PIX=1
MIN_RUN=3
AREA_THRESHOLD=30000

# SAM Optimisation
SAM_CACHE_SIZE=4    # LRU embedding cache — set to 0 to disable
SAM_FP16=false      # Half-precision encoder on CUDA — enable with caution, validate accuracy first

# Anomaly Detection
ANOMALY_ENABLED=true
ANOMALY_MODEL_PATH=Model/Anomaly/yolox_m_washanomaly20MAY.onnx
ANOMALY_MODEL_CLASSES=waste      # comma-separated list of class names the anomaly model was trained on
ANOMALY_CONF_THR=0.5

# Output
OUTPUT_DIR=RESULT/api_results
